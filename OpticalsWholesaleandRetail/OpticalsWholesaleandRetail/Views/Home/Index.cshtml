@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <title>Optical POS Dashboard</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body>

    <div class="wrapper">

        <!-- Sidebar -->

        <div class="sidebar">

            <div class="sidebar-header">
                OPTICAL POS
            </div>

            <ul class="sidebar-menu">

                <li><a href="#"><i class="fas fa-home"></i>Dashboard</a></li>

                <li><a href="#"><i class="fas fa-shopping-cart"></i>Orders</a></li>

                <li>
                    <a asp-controller="UserManagement" asp-action="GetUser">
                        <i class="fas fa-users"></i>Customers
                    </a>
                </li>

                <li><a href="#"><i class="fas fa-dollar-sign"></i>Purchase Price</a></li>

                <li><a href="#"><i class="fas fa-file-invoice"></i>Invoices</a></li>

                <li><a href="#"><i class="fas fa-sign-out-alt text-danger"></i>Logout</a></li>

            </ul>

        </div>

        <!-- Main Content -->

        <div class="main-content">

            <h3 class="mb-4">Admin Dashboard</h3>

            <div class="row g-4">

                <div class="col-md-3">
                    <div class="stat-card">
                        <h2>250</h2>
                        <p>Total Orders</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="stat-card">
                        <h2>$45,000</h2>
                        <p>Revenue</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="stat-card">
                        <h2>12</h2>
                        <p>Suppliers</p>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="stat-card">
                        <h2>85%</h2>
                        <p>Growth</p>
                    </div>
                </div>

            </div>

            <div class="row">

                <div class="col-md-6">

                    <div class="chart-box">
                        <canvas id="salesChart"></canvas>
                    </div>

                </div>

                <div class="col-md-6">

                    <div class="chart-box">
                        <canvas id="productChart"></canvas>
                    </div>

                </div>

            </div>

        </div>

    </div>

    <script>

        /* Sales Chart */

        new Chart(document.getElementById("salesChart"), {
            type: "bar",
            data: {
                labels: ["Jan", "Feb", "Mar", "Apr", "May", "Jun"],
                datasets: [{
                    label: "Monthly Sales",
                    data: [1200, 1900, 3000, 5000, 2400, 3500],
                    backgroundColor: "#22d3ee"
                }]
            },
            options: {
                plugins: { legend: { display: false } }
            }
        });


        /* Product Pie */

        new Chart(document.getElementById("productChart"), {
            type: "pie",
            data: {
                labels: ["Rio", "Ghag", "Crizal"],
                datasets: [{
                    data: [40, 30, 30],
                    backgroundColor: [
                        "#22d3ee",
                        "#ff00ff",
                        "#00ff99"
                    ]
                }]
            }
        });

    </script>

</body>
</html>