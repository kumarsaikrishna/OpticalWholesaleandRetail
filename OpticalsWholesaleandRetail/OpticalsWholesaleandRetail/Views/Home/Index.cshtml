@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Optical ERP Dashboard</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <style>

        body {
            margin: 0;
            font-family: 'Segoe UI';
            background: #f4f6f9;
        }

        /* Layout */
        .wrapper {
            display: flex;
        }

        /* Sidebar */

        .sidebar {
            width: 240px;
            height: 100vh;
            background: #111827;
            color: white;
            position: fixed;
        }

        .sidebar-header {
            padding: 20px;
            text-align: center;
            background: #000;
            font-size: 20px;
            font-weight: bold;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .sidebar-menu li {
                border-bottom: 1px solid rgba(255,255,255,0.05);
            }

                .sidebar-menu li a {
                    display: block;
                    padding: 15px 20px;
                    color: #ccc;
                    text-decoration: none;
                }

                    .sidebar-menu li a:hover {
                        background: #007bff;
                        color: white;
                    }

            .sidebar-menu i {
                margin-right: 10px;
            }

        /* Main Content */

        .main-content {
            margin-left: 240px;
            width: 100%;
            padding: 20px;
        }

        /* Dashboard Cards */

        .prod-p-card {
            transition: 0.3s;
            cursor: pointer;
        }

            .prod-p-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            }
    </style>

</head>

<body>

    <div class="wrapper">

        <!-- Sidebar -->

        <div class="sidebar">

            <div class="sidebar-header">
                <i class="fas fa-glasses"></i> Optical ERP
            </div>

            <ul class="sidebar-menu">

                <li>
                    <a href="#">
                        <i class="fas fa-home"></i> Dashboard
                    </a>
                </li>

                <li>
                    <a asp-controller="UserManagement" asp-action="GetUser">
                        <i class="fas fa-users"></i> Customers
                    </a>
                </li>

                <li>
                    <a asp-controller="UserManagement" asp-action="GetUserTypes">
                        <i class="fas fa-eye"></i> User Types
                    </a>
                </li>

                <li>
                    <a href="#">
                        <i class="fas fa-glasses"></i> Frames Inventory
                    </a>
                </li>

                <li>
                    <a href="#">
                        <i class="fas fa-circle"></i> Lens Inventory
                    </a>
                </li>

                <li>
                    <a href="#">
                        <i class="fas fa-shopping-cart"></i> Orders
                    </a>
                </li>

                <li>
                    <a href="#">
                        <i class="fas fa-receipt"></i> Billing
                    </a>
                </li>

                <li>
                    <a href="#">
                        <i class="fas fa-truck"></i> Suppliers
                    </a>
                </li>

                <li>
                    <a href="#">
                        <i class="fas fa-chart-bar"></i> Reports
                    </a>
                </li>

                <li>
                    <a href="#">
                        <i class="fas fa-cog"></i> Settings
                    </a>
                </li>

            </ul>

        </div>

        <!-- Main Content -->

        <div class="main-content">

            <div class="container-fluid">

                <div class="row mb-4">
                    <div class="col">
                        <h3>Dashboard</h3>
                    </div>
                </div>

                <div class="row">

                    <!-- Total Subscriptions -->

                    <div class="col-xl-3 col-md-6">
                        <div class="card prod-p-card bg-primary text-white" onclick="loadSubscriptions()">
                            <div class="card-body">

                                <h6>Total Subscriptions</h6>

                                <h3>@ViewBag.TotalSubscriptions</h3>

                                <i class="fas fa-money-bill-alt"></i>

                            </div>
                        </div>
                    </div>

                    <!-- Renewals -->

                    <div class="col-xl-3 col-md-6">
                        <div class="card prod-p-card bg-info text-white" onclick="openRenewalList()">
                            <div class="card-body">

                                <h6>Renewals</h6>

                                <h3>0</h3>

                                <i class="fas fa-sync"></i>

                            </div>
                        </div>
                    </div>

                    <!-- Closed Subscriptions -->

                    <div class="col-xl-3 col-md-6">
                        <div id="closedSubscriptionsCard" class="card prod-p-card bg-success text-white">
                            <div class="card-body">

                                <h6>Closed Subscriptions</h6>

                                <h3>0</h3>

                                <i class="fas fa-check"></i>

                            </div>
                        </div>
                    </div>

                    <!-- Product Sold -->

                    <div class="col-xl-3 col-md-6">
                        <div class="card prod-p-card bg-warning text-white">
                            <div class="card-body">

                                <h6>Product Sold</h6>

                                <h3>6784</h3>

                                <i class="fas fa-tags"></i>

                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- Subscription Modal -->

    <div class="modal fade" id="subscriptionModal">

        <div class="modal-dialog modal-lg">

            <div class="modal-content">

                <div class="modal-header">

                    <h5>Total Subscriptions</h5>

                    <button class="btn-close" data-bs-dismiss="modal"></button>

                </div>

                <div class="modal-body">

                    <table class="table table-bordered">

                        <thead>

                            <tr>

                                <th>#</th>
                                <th>Name</th>
                                <th>Start</th>
                                <th>End</th>
                                <th>Status</th>

                            </tr>

                        </thead>

                        <tbody id="subscriptionTableBody">
                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

    <script>

        function loadSubscriptions() {

            $.ajax({

                url: '/Home/GetSubscriptions',

                type: 'GET',

                success: function (res) {

                    $("#subscriptionTableBody").empty();

                    res.data.forEach((item, index) => {

                        $("#subscriptionTableBody").append(`

<tr>

<td>${index + 1}</td>

<td>${item.Name}</td>

<td>${item.StartDate}</td>

<td>${item.EndDate}</td>

<td>${item.Status}</td>

</tr>

`);

                    });

                    $('#subscriptionModal').modal('show');

                }

            });

        }

    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>