<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OpticalFibersRetailShop</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>

        body {
            margin: 0;
        }

        .wrapper {
            display: flex;
        }

        /* Sidebar */

        .sidebar {
            width: 240px;
            height: 100vh;
            background: #111827;
            color: white;
            position: fixed;
        }

        .sidebar-header {
            padding: 20px;
            font-size: 20px;
            text-align: center;
            background: #000;
        }

        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .sidebar-menu li a {
                display: block;
                padding: 15px 20px;
                color: #ddd;
                text-decoration: none;
            }

                .sidebar-menu li a:hover {
                    background: #007bff;
                    color: white;
                }

        /* Main content */

        .main-content {
            margin-left: 240px;
            width: 100%;
        }
    </style>

</head>

<body>

    <div class="wrapper">

        <!-- Sidebar -->

        <div class="sidebar">

            <div class="sidebar-header">
                <i class="fas fa-glasses"></i> Optical Shop
            </div>

            <ul class="sidebar-menu">

                <li>
                    <a asp-controller="Home" asp-action="Index">
                        <i class="fas fa-home"></i> Dashboard
                    </a>
                </li>

                <li>
                    <a asp-controller="Usermanagemant" asp-action="GetUsers">
                        <i class="fas fa-users"></i> Customers
                    </a>
                </li>

                <li>
                    <a asp-controller="Orders" asp-action="Index">
                        <i class="fas fa-shopping-cart"></i> Orders
                    </a>
                </li>

                <li>
                    <a asp-controller="Inventory" asp-action="Index">
                        <i class="fas fa-glasses"></i> Frames Inventory
                    </a>
                </li>

                <li>
                    <a asp-controller="Lens" asp-action="Index">
                        <i class="fas fa-eye"></i> Lens Inventory
                    </a>
                </li>

                <li>
                    <a asp-controller="Reports" asp-action="Index">
                        <i class="fas fa-chart-bar"></i> Reports
                    </a>
                </li>

            </ul>

        </div>


        <!-- Main Area -->

        <div class="main-content">

            <header>
                <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
                    <div class="container-fluid">

                        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                            OpticalFibersRetailShop
                        </a>

                    </div>
                </nav>
            </header>

            <div class="container">

                <main role="main" class="pb-3">
                    @RenderBody()
                </main>

            </div>

            <footer class="border-top footer text-muted">
                <div class="container">
                    &copy; 2026 - OpticalFibersRetailShop -
                    <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
            </footer>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>