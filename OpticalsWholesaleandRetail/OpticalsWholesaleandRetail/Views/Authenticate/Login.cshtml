@model OpticalsWholesaleandRetail.Models.DTO.LoginRequest

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Optical Shop Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />

    <style>

        html, body {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI',sans-serif;
        }

        /* Full screen optical background */
        body {
            background: url('/Resources/assets/images/pexels-kseniachernaya-5752269') no-repeat center center fixed;
            background-size: cover;
            position: relative;
        }

            /* Dark overlay */
            body::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0,0,0,0.6);
            }

        /* Center container */
        .main-container {
            position: relative;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* Login card */
        .login-card {
            width: 100%;
            max-width: 420px;
            padding: 35px;
            border-radius: 12px;
            backdrop-filter: blur(12px);
            background: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.3);
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
            color: white;
        }

            /* Heading */
            .login-card h4 {
                text-align: center;
                font-weight: 600;
                margin-bottom: 25px;
            }

        /* labels */
        .form-label {
            color: #f1f1f1;
        }

        /* inputs */
        .form-control {
            background: rgba(255,255,255,0.9);
            border: none;
            height: 45px;
        }

        /* login button */
        .btn-primary {
            height: 45px;
            font-weight: 600;
            background: #007bff;
            border: none;
        }

            .btn-primary:hover {
                background: #0056b3;
            }

        /* forgot password */
        a {
            color: #ddd;
            font-size: 14px;
        }

            a:hover {
                color: white;
            }

        /* footer */
        .page-footer {
            position: absolute;
            bottom: 10px;
            width: 100%;
            text-align: center;
            color: #ddd;
            font-size: 13px;
        }

        /* password eye icon */
        .password-wrapper {
            position: relative;
        }

        .toggle-password {
            position: absolute;
            top: 38px;
            right: 12px;
            cursor: pointer;
            color: #333;
        }
    </style>

</head>

<body>

    <div class="main-container">

        <div class="login-card">

            <h4>
                <i class="fas fa-glasses"></i> Optical Shop Login
            </h4>

            <form asp-action="Login" method="post">

                <div class="mb-3">
                    <label asp-for="Uname" class="form-label">Email Address</label>
                    <input asp-for="Uname" class="form-control" placeholder="advisor@example.com" />
                    <span asp-validation-for="Uname" class="text-danger"></span>
                </div>

                <div class="mb-3 password-wrapper">
                    <label asp-for="Password" class="form-label">Password</label>

                    <input asp-for="Password"
                           type="password"
                           class="form-control"
                           id="passwordInput"
                           placeholder="Enter password" />

                    <i class="fa fa-eye toggle-password"
                       id="togglePasswordIcon"
                       onclick="togglePassword()"
                       title="Show Password"></i>

                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mb-3">
                    <a asp-controller="Authenticate" asp-action="ForgotPassword">
                        Forgot Password?
                    </a>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    Login
                </button>

            </form>

        </div>

        <div class="page-footer">
            © @DateTime.Now.Year Optical Retail ERP
        </div>

    </div>

    <script>

        function togglePassword() {

            const passwordInput = document.getElementById("passwordInput");
            const icon = document.getElementById("togglePasswordIcon");

            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            }
            else {
                passwordInput.type = "password";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            }

        }

    </script>

</body>
</html>