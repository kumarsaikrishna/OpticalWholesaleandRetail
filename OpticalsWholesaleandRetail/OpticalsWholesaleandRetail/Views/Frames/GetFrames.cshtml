@model IEnumerable<OpticalsWholesaleandRetail.Models.DTO.FrameBrandDto>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    int sno = 1;
}

<style>
    .required {
        color: red;
    }

    .modal-dialog {
        max-width: 90%;
        width: 90%;
    }

    th {
        font-weight: bold;
    }
</style>

<div class="main-panel">
    <div class="content-wrapper">
        <div class="container-full">

            <div class="col-md-12 mt-3">
                <div class="card">

                    <div class="card-header d-flex justify-content-between align-items-center">

                        <h4 class="card-title mb-0">Frame Brands</h4>

                        <input type="text" id="searchInput" class="form-control"
                               placeholder="Search Brands..." style="width:300px;" />

                        <button class="btn btn-primary" onclick="openAddModal()">
                            <i class="fa fa-plus"></i> Add Brand
                        </button>

                    </div>

                    <div class="card-body">

                        <div class="table-responsive">

                            <table class="table table-striped">

                                <thead>

                                    <tr>
                                        <th>#</th>
                                        <th>Brand Name</th>
                                        <th>Category</th>
                                        <th>Supplier</th>
                                        <th>Action</th>
                                    </tr>

                                </thead>

                                <tbody id="brandTableBody">

                                    @foreach (var brand in Model)
                                    {
                                        <tr>

                                            <td>@sno</td>

                                            <td>@brand.BrandName</td>

                                            <td>@brand.Category</td>

                                            <td>@brand.SupplierName</td>

                                            <td>

                                                <button class="btn btn-circle btn-primary btn-xs"
                                                        onclick="EditBrand('@brand.BrandId','@brand.BrandName','@brand.Category','@brand.SupplierId')">

                                                    <i class="fa fa-edit"></i>

                                                </button>

                                                <button class="btn btn-circle btn-danger btn-xs"
                                                        onclick="DeleteBrand('@brand.BrandId')">

                                                    <i class="fa fa-trash"></i>

                                                </button>

                                            </td>

                                        </tr>

                                        sno++;
                                    }

                                </tbody>

                            </table>

                        </div>

                        <ul id="pagination" class="pagination justify-content-end"></ul>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ADD BRAND MODAL -->

<div class="modal fade" id="addModal">

    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Add Frame Brand</h5>
            </div>

            <div class="modal-body">

                <form id="brandForm">

                    @Html.AntiForgeryToken()

                    <div class="row">

                        <div class="col-md-6">

                            <label>Brand Name <span class="required">*</span></label>

                            <input type="text"
                                   name="BrandName"
                                   class="form-control"
                                   required />

                        </div>

                        <div class="col-md-6">

                            <label>Category</label>

                            <select name="Category" class="form-control">

                                <option value="">Select</option>
                                <option value="Metal">Metal</option>
                                <option value="Plastic">Plastic</option>
                                <option value="Rimless">Rimless</option>

                            </select>

                        </div>

                        <div class="col-md-6 mt-3">

                            <label>Supplier</label>

                            <select name="SupplierId" class="form-control">

                                <option value="">Select Supplier</option>

                                @foreach (var item in ViewBag.Suppliers)
                                {
                                    <option value="@item.SupplierId">@item.ContactPerson</option>
                                }

                            </select>

                        </div>

                    </div>

                    <div class="modal-footer">

                        <button type="submit" class="btn btn-primary">
                            Save
                        </button>

                        <button type="button" class="btn btn-danger"
                                data-dismiss="modal">
                            Cancel
                        </button>

                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

<!-- EDIT BRAND MODAL -->

<div class="modal fade" id="editBrandModal">

    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Edit Frame Brand</h5>
            </div>

            <div class="modal-body">

                <form id="editBrandForm">

                    @Html.AntiForgeryToken()

                    <input type="hidden" id="editBrandId" name="BrandId" />

                    <div class="row">

                        <div class="col-md-6">

                            <label>Brand Name</label>

                            <input type="text"
                                   id="editBrandName"
                                   name="BrandName"
                                   class="form-control" />

                        </div>

                        <div class="col-md-6">

                            <label>Category</label>

                            <select id="editCategory"
                                    name="Category"
                                    class="form-control">

                                <option value="Metal">Metal</option>
                                <option value="Plastic">Plastic</option>
                                <option value="Rimless">Rimless</option>

                            </select>

                        </div>

                        <div class="col-md-6 mt-3">

                            <label>Supplier</label>

                            <select id="editSupplierId"
                                    name="SupplierId"
                                    class="form-control">

                                <option value="">Select Supplier</option>

                                @foreach (var item in ViewBag.Suppliers)
                                {
                                    <option value="@item.SupplierId">@item.ContactPerson</option>
                                }

                            </select>

                        </div>

                    </div>

                    <div class="modal-footer">

                        <button type="submit" class="btn btn-primary">
                            Update
                        </button>

                        <button type="button" class="btn btn-danger"
                                data-dismiss="modal">
                            Cancel
                        </button>

                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

<script>

    function openAddModal() {

        $('#addModal').modal('show');

    }

    function EditBrand(id, name, category, supplierId) {

        $('#editBrandId').val(id);
        $('#editBrandName').val(name);
        $('#editCategory').val(category);
        $('#editSupplierId').val(supplierId);

        $('#editBrandModal').modal('show');

    }

    $('#brandForm').submit(function (e) {

        e.preventDefault();

        var formData = new FormData(this);

        $.ajax({

            url: '/Frames/AddFrameBrands',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,

            success: function (res) {

                if (res.success) {

                    Swal.fire("Success", "Brand Added Successfully", "success")
                        .then(() => location.reload());

                } else {

                    Swal.fire("Error", res.message, "error");

                }

            }

        });

    });

    $('#editBrandForm').submit(function (e) {

        e.preventDefault();

        var formData = new FormData(this);

        $.ajax({

            url: '/Frames/UpdateFrameBrand',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,

            success: function (res) {

                if (res.success) {

                    Swal.fire("Updated", "Brand Updated", "success")
                        .then(() => location.reload());

                }

            }

        });

    });

    function DeleteBrand(id) {

        Swal.fire({

            title: "Are you sure?",
            text: "You won't be able to revert this!",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#d33",
            cancelButtonColor: "#3085d6",
            confirmButtonText: "Yes, delete it!"

        }).then((result) => {

            if (result.isConfirmed) {

                $.ajax({

                    url: '/Frames/DeleteFrameBrand/' + id,
                    type: 'POST',

                    success: function (res) {

                        if (res.success) {

                            Swal.fire("Deleted", "Brand Deleted", "success")
                                .then(() => location.reload());

                        }

                    }

                });

            }

        });

    }

    $(document).ready(function () {

        $('#searchInput').on('keyup', function () {

            var value = $(this).val().toLowerCase();

            $("#brandTableBody tr").filter(function () {

                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)

            });

        });

    });

</script>